# Microsoft Entra ID Configuration
# Obtener estos valores desde https://portal.azure.com/

# ID de la aplicación registrada en Azure AD
MICROSOFT_CLIENT_ID=your-client-id-from-azure

# Secreto de la aplicación
MICROSOFT_CLIENT_SECRET=your-client-secret-from-azure

# ID del tenant (directorio)
MICROSOFT_TENANT_ID=your-tenant-id

# URI de redirección (debe coincidir con lo configurado en Azure)
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/callback

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bbraun

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend
FRONTEND_URL=http://localhost:5173
